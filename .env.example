# Copy to .env and fill in to use a real LLM. No secrets are committed.
# Default (unset) uses the deterministic offline FakeProvider.
# LLM_MODEL uses litellm "provider/model" naming — swap provider by changing it.
LLM_PROVIDER=real
LLM_MODEL=gemini/gemini-2.5-flash
LLM_API_KEY=...
# LLM_BASE_URL=   # optional: only for custom/self-hosted endpoints (litellm api_base)
